# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=mymusic
DB_PASSWORD=mymusic_password
DB_NAME=mymusic_db

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── AWS S3 ───────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_AUDIO=mymusic-audio
AWS_S3_BUCKET_AUDIO_ENC=mymusic-audio-enc
AWS_S3_BUCKET_IMAGES=mymusic-images
AWS_S3_PRESIGN_EXPIRES_SEC=3600

# ── Gmail SMTP ───────────────────────────────────
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password
MAIL_FROM=your_email@gmail.com

# ── Python DSP Sidecar ───────────────────────────
DSP_URL=http://dsp:5000

# ── VNPay ────────────────────────────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay

# ── MoMo ─────────────────────────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/momo
MOMO_NOTIFY_URL=http://localhost:3001/api/v1/payment/momo/callback

# ── Downloads ─────────────────────────────────────────────────────
DOWNLOAD_JWT_SECRET=change_me_download_jwt_secret_at_least_32_chars
VNPAY_CALLBACK_URL=http://localhost:3001/api/v1/payment/vn-pay/callback
