# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=mymusic
DB_PASSWORD=mymusic_password
DB_NAME=mymusic_db

# ── Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── MinIO ────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_IMAGES=images

# ── SMTP (MailHog in dev — swap for real SMTP in prod) ──
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mymusic.local

# ── Python DSP Sidecar ───────────────────────────
DSP_URL=http://dsp:5000

# ── VNPay ────────────────────────────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay

# ── MoMo ─────────────────────────────────────────
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/momo
MOMO_NOTIFY_URL=http://localhost:3001/api/v1/payment/momo/callback

# ── Downloads ─────────────────────────────────────────────────────
DOWNLOAD_JWT_SECRET=change_me_download_jwt_secret_at_least_32_chars
VNPAY_CALLBACK_URL=http://localhost:3001/api/v1/payment/vn-pay/callback
