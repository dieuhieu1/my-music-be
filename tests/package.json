{
  "name": "@mymusic/tests",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "test:api":        "jest --config jest.config.ts",
    "test:api:phase1": "jest --config jest.config.ts --testPathPattern=phase1",
    "test:api:phase2": "jest --config jest.config.ts --testPathPattern=phase2",
    "test:api:phase3": "jest --config jest.config.ts --testPathPattern=phase3",
    "test:api:phase4a":"jest --config jest.config.ts --testPathPattern=phase4a",
    "test:api:phase4b":"jest --config jest.config.ts --testPathPattern=phase4b",
    "test:api:phase5": "jest --config jest.config.ts --testPathPattern=phase5",
    "test:api:phase6": "jest --config jest.config.ts --testPathPattern=phase6",
    "test:api:phase7": "jest --config jest.config.ts --testPathPattern=phase7",
    "test:api:phase8": "jest --config jest.config.ts --testPathPattern=phase8",
    "test:api:phase9": "jest --config jest.config.ts --testPathPattern=phase9",
    "test:e2e":        "playwright test --config playwright.config.ts",
    "test:e2e:phase1": "playwright test --config playwright.config.ts --project=phase1",
    "test:e2e:phase2": "playwright test --config playwright.config.ts --project=phase2",
    "test:e2e:phase3": "playwright test --config playwright.config.ts --project=phase3",
    "test:e2e:phase4a":"playwright test --config playwright.config.ts --project=phase4a",
    "test:e2e:phase4b":"playwright test --config playwright.config.ts --project=phase4b",
    "test:e2e:phase5": "playwright test --config playwright.config.ts --project=phase5",
    "test:e2e:phase6": "playwright test --config playwright.config.ts --project=phase6",
    "test:e2e:phase7": "playwright test --config playwright.config.ts --project=phase7",
    "test:e2e:phase8": "playwright test --config playwright.config.ts --project=phase8",
    "test:e2e:phase9": "playwright test --config playwright.config.ts --project=phase9"
  },
  "dependencies": {
    "axios": "^1.7.3",
    "axios-cookiejar-support": "^4.0.7",
    "tough-cookie": "^4.1.4",
    "uuid": "^10.0.0",
    "pg": "^8.12.0",
